# ============================================
# AI GitHub Codebase Assistant — Environment
# ============================================

# Google Gemini (free — get key from https://aistudio.google.com/)
GOOGLE_API_KEY=your_google_api_key_here

# Pinecone (free — get key from https://app.pinecone.io/)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=codebase-rag

# GitHub (optional — increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Backend
FASTAPI_PORT=8000

# CORS (comma-separated for production)
# CORS_ORIGINS=https://your-frontend.vercel.app

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
